def render_human(rep: Report, verbose: bool) -> None:
    by_section: dict[str, list[CheckResult]] = {"sys": [], "bot": [], "wg": [], "net": []}
    for c in rep.checks:
        by_section.setdefault(c.section, []).append(c)

    icons = {"ok": OK, "warn": WARN, "fail": FAIL, "skip": INFO}
    titles = {
        "sys": "FILESYSTEM, PERMISSIONS, SYSTEMD",
        "bot": "BOT SERVICE, CONFIG, CONNECTIVITY",
        "wg": "WIREGUARD INTERFACE AND PEER STATE",
        "net": "NETWORK: IP FORWARDING, NAT, INTERFACES",
    }

    for section in ["sys", "bot", "wg", "net"]:
        if not by_section.get(section):
            continue
        print(f"\n{C_BOLD}── {titles[section]} ──{C_RESET}\n")
        for c in by_section[section]:
            if c.status == "ok" and not verbose:
                continue
            icon = icons[c.status]
            line = f"  {icon} {c.message}"
            if c.fix_applied:
                line += f" {C_GREEN}[fixed]{C_RESET}"
            elif c.fixable and c.status in ("warn", "fail"):
                line += f" {C_DIM}[--fix available]{C_RESET}"
            print(line)
            if c.detail and c.status != "ok":
                for dl in c.detail.splitlines():
                    print(f"      {C_DIM}{dl}{C_RESET}")

    # Summary
    s = rep.summary()
    total = sum(s.values())
    print(f"\n{C_BOLD}── SUMMARY ──{C_RESET}")
    print(f"  {OK} ok:    {s['ok']}/{total}")
    if s["warn"]:  print(f"  {WARN} warn:  {s['warn']}")
    if s["fail"]:  print(f"  {FAIL} fail:  {s['fail']}")
    if s["skip"]:  print(f"  {INFO} skip:  {s['skip']}")
    if s["fail"] == 0 and s["warn"] == 0:
        print(f"\n{C_GREEN}{C_BOLD}All clear.{C_RESET}\n")
    elif s["fail"] == 0:
        print(f"\n{C_YELLOW}Warnings only — not blocking but worth a look.{C_RESET}\n")
    else:
        print(f"\n{C_RED}{C_BOLD}Failures present.{C_RESET} "
              f"Run with --fix to attempt auto-repair, "
              f"or investigate manually.\n")


def render_json(rep: Report) -> None:
    print(json.dumps({
        "started_at": rep.started_at,
        "summary": rep.summary(),
        "checks": [asdict(c) for c in rep.checks],
    }, indent=2))


def main() -> int:
    ap = argparse.ArgumentParser(
        description="Audit and (optionally) repair a wg-vpn-bot install.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    ap.add_argument("--fix", action="store_true",
                    help="Apply safe automatic fixes for failing checks where possible")
    ap.add_argument("--section", choices=["sys", "bot", "wg", "net", "all"], default="all",
                    help="Limit checks to one section (default: all)")
    ap.add_argument("--json", action="store_true",
                    help="Output JSON instead of human-readable report")
    ap.add_argument("--verbose", action="store_true",
                    help="Show passing checks too (default: only show issues)")
    args = ap.parse_args()

    if args.fix and os.geteuid() != 0:
        print(f"{FAIL} --fix requires root. Try: sudo wg-bot-doctor --fix",
              file=sys.stderr)
        return 2

    rep = Report()
    sections = ["sys", "bot", "wg", "net"] if args.section == "all" else [args.section]

    for section in sections:
        for check in CHECKS[section]:
            try:
                check(rep, fix=args.fix)
            except Exception as e:
                rep.add(CheckResult(
                    name=check.__name__,
                    section=section,
                    status="fail",
                    message=f"check {check.__name__} crashed",
                    detail=f"{type(e).__name__}: {e}",
                ))

    if args.json:
        render_json(rep)
    else:
        render_human(rep, args.verbose)

    s = rep.summary()
    if s["fail"]:
        return 1
    if s["warn"]:
        return 0  # warnings are non-blocking for exit code
    return 0


if __name__ == "__main__":
    sys.exit(main())
