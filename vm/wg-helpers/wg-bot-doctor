FIFO = Path("/run/wg-bot.fifo")

# ---------- ui ----------
USE_COLOR = sys.stdout.isatty()
C_RED    = "\033[31m" if USE_COLOR else ""
C_GREEN  = "\033[32m" if USE_COLOR else ""
C_YELLOW = "\033[33m" if USE_COLOR else ""
C_CYAN   = "\033[36m" if USE_COLOR else ""
C_BOLD   = "\033[1m"  if USE_COLOR else ""
C_DIM    = "\033[2m"  if USE_COLOR else ""
C_RESET  = "\033[0m"  if USE_COLOR else ""

OK   = f"{C_GREEN}✓{C_RESET}"
FAIL = f"{C_RED}✗{C_RESET}"
WARN = f"{C_YELLOW}⚠{C_RESET}"
INFO = f"{C_CYAN}ℹ{C_RESET}"


@dataclass
class CheckResult:
    name: str
    section: str
    status: str  # "ok" | "warn" | "fail" | "skip"
    message: str
    detail: str = ""
    fixable: bool = False
    fix_applied: bool = False
    fix_output: str = ""


@dataclass
class Report:
    started_at: float = field(default_factory=time.time)
    checks: list[CheckResult] = field(default_factory=list)

    def add(self, r: CheckResult) -> None:
        self.checks.append(r)

    def summary(self) -> dict[str, int]:
        out = {"ok": 0, "warn": 0, "fail": 0, "skip": 0}
        for c in self.checks:
            out[c.status] = out.get(c.status, 0) + 1
        return out


# =========== helpers ===========

def _run(cmd: list[str], timeout: int = 10) -> tuple[int, str, str]:
    """Run a command, capture output. Doesn't raise."""
    try:
        p = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return p.returncode, p.stdout.strip(), p.stderr.strip()
    except FileNotFoundError:
        return 127, "", f"command not found: {cmd[0]}"
    except subprocess.TimeoutExpired:
        return 124, "", f"timed out after {timeout}s"
    except Exception as e:
        return 1, "", f"{type(e).__name__}: {e}"


def _stat_path(p: Path) -> dict[str, Any] | None:
    try:
        st = p.lstat()
    except FileNotFoundError:
        return None
    try:
        owner = pwd.getpwuid(st.st_uid).pw_name
    except KeyError:
        owner = str(st.st_uid)
    try:
        import grp
        group = grp.getgrgid(st.st_gid).gr_name
    except KeyError:
        group = str(st.st_gid)
    return {
        "owner": owner, "group": group,
        "mode": stat.S_IMODE(st.st_mode),
        "mode_str": stat.filemode(st.st_mode),
        "is_fifo": stat.S_ISFIFO(st.st_mode),
        "is_dir":  stat.S_ISDIR(st.st_mode),
        "size": st.st_size,
    }


def _load_yaml(path: Path) -> dict | None:
    try:
        import yaml
    except ImportError:
        return None
    try:
        with path.open() as f:
            return yaml.safe_load(f) or {}
    except Exception:
        return None


def _load_json(path: Path) -> dict | None:
    try:
        with path.open() as f:
            return json.load(f) or {}
    except Exception:
        return None


# =========== SYS section ===========

def check_sys_wg_dir(rep: Report, fix: bool) -> None:
    """Directory must be 750 root:wgbot for the bot to traverse and read.

    750 (not 770) is correct because the bot writes wg0.conf in place
    (truncate-and-write), not via .tmp + rename. So wgbot needs traverse
    and list on the dir, but not write access on the dir itself."""
    s = _stat_path(WG_DIR)
    if s is None:
        rep.add(CheckResult("sys.wg_dir.exists", "sys", "fail",
                            f"{WG_DIR} does not exist",
                            "Install wireguard package: apt install wireguard"))
        return
    if not s["is_dir"]:
        rep.add(CheckResult("sys.wg_dir.exists", "sys", "fail",
                            f"{WG_DIR} is not a directory"))
        return
    bad = []
    if s["owner"] != "root": bad.append(f"owner={s['owner']} (want root)")
    if s["group"] != "wgbot": bad.append(f"group={s['group']} (want wgbot)")
    if s["mode"] != 0o750: bad.append(f"mode={oct(s['mode'])} (want 0o750)")
    if not bad:
        rep.add(CheckResult("sys.wg_dir.perms", "sys", "ok",
                            f"{WG_DIR} is 750 root:wgbot ✓"))
        return
    detail = f"current: {s['mode_str']} {s['owner']}:{s['group']}"
    if fix:
        _run(["chown", "root:wgbot", str(WG_DIR)])
        _run(["chmod", "750", str(WG_DIR)])
        s2 = _stat_path(WG_DIR)
        if s2 and s2["owner"] == "root" and s2["group"] == "wgbot" and s2["mode"] == 0o750:
            rep.add(CheckResult("sys.wg_dir.perms", "sys", "ok",
                                "Fixed: now 750 root:wgbot", detail,
                                fixable=True, fix_applied=True))
            return
    rep.add(CheckResult("sys.wg_dir.perms", "sys", "fail",
                        f"{WG_DIR} permissions wrong: {', '.join(bad)}",
                        detail, fixable=True))


def check_sys_wg_conf(rep: Report, fix: bool) -> None:
    """wg0.conf must be 660 root:wgbot."""
    s = _stat_path(WG_CONF)
    if s is None:
        rep.add(CheckResult("sys.wg_conf.exists", "sys", "fail",
                            f"{WG_CONF} does not exist",
                            "WireGuard server config not created. Check startup log."))
        return
    bad = []
    if s["owner"] != "root": bad.append(f"owner={s['owner']} (want root)")
    if s["group"] != "wgbot": bad.append(f"group={s['group']} (want wgbot)")
    if s["mode"] != 0o660: bad.append(f"mode={oct(s['mode'])} (want 0o660)")
    if not bad:
        rep.add(CheckResult("sys.wg_conf.perms", "sys", "ok",
                            f"{WG_CONF} is 660 root:wgbot ✓"))
        return
    detail = f"current: {s['mode_str']} {s['owner']}:{s['group']}"
    if fix:
        _run(["chown", "root:wgbot", str(WG_CONF)])
        _run(["chmod", "660", str(WG_CONF)])
        s2 = _stat_path(WG_CONF)
        if s2 and s2["owner"] == "root" and s2["group"] == "wgbot" and s2["mode"] == 0o660:
            rep.add(CheckResult("sys.wg_conf.perms", "sys", "ok",
                                "Fixed: now 660 root:wgbot", detail,
                                fixable=True, fix_applied=True))
            return
    rep.add(CheckResult("sys.wg_conf.perms", "sys", "fail",
                        f"{WG_CONF} permissions wrong: {', '.join(bad)}",
                        detail + "\n"
                        "If this keeps reverting, wg-quick save is being called "
                        "without the wg-save-restore wrapper.", fixable=True))


def check_sys_fifo(rep: Report, fix: bool) -> None:
    s = _stat_path(FIFO)
    if s is None:
        if fix:
            _run(["mkfifo", str(FIFO)])
            _run(["chown", "wgbot:wgbot", str(FIFO)])
            _run(["chmod", "622", str(FIFO)])
            s2 = _stat_path(FIFO)
            if s2 and s2["is_fifo"]:
                rep.add(CheckResult("sys.fifo.exists", "sys", "ok",
                                    "Fixed: FIFO created", fixable=True, fix_applied=True))
                return
        rep.add(CheckResult("sys.fifo.exists", "sys", "fail",
                            f"{FIFO} does not exist",
                            "Watchers can't deliver alerts. Restart bot or run "
                            "systemd-tmpfiles --create /etc/tmpfiles.d/wg-admin-bot.conf",
                            fixable=True))
        return
    if not s["is_fifo"]:
        rep.add(CheckResult("sys.fifo.exists", "sys", "fail",
                            f"{FIFO} exists but is not a FIFO ({s['mode_str']})",
                            "Delete and recreate"))
        return
    bad = []
    if s["owner"] != "wgbot": bad.append(f"owner={s['owner']} (want wgbot)")
    if s["group"] != "wgbot": bad.append(f"group={s['group']} (want wgbot)")
    if s["mode"] != 0o622: bad.append(f"mode={oct(s['mode'])} (want 0o622)")
    if not bad:
        rep.add(CheckResult("sys.fifo.perms", "sys", "ok",
                            "FIFO is 622 wgbot:wgbot ✓"))
        return
    if fix:
        _run(["chown", "wgbot:wgbot", str(FIFO)])
        _run(["chmod", "622", str(FIFO)])
        rep.add(CheckResult("sys.fifo.perms", "sys", "ok",
                            "Fixed: FIFO now 622 wgbot:wgbot", fixable=True, fix_applied=True))
        return
    rep.add(CheckResult("sys.fifo.perms", "sys", "warn",
                        f"FIFO perms off: {', '.join(bad)}", fixable=True))


def check_sys_tmpfiles_rule(rep: Report, fix: bool) -> None:
    if not TMPFILES.exists():
        rep.add(CheckResult("sys.tmpfiles.exists", "sys", "warn",
                            f"{TMPFILES} missing",
                            "Without this rule, FIFO won't survive reboot. "
                            "Recreate manually or reinstall."))
        return
    content = TMPFILES.read_text()
    if "/run/wg-bot.fifo" not in content:
        rep.add(CheckResult("sys.tmpfiles.rule", "sys", "warn",
                            "tmpfiles.d rule doesn't mention FIFO",
                            content))
        return
    rep.add(CheckResult("sys.tmpfiles.rule", "sys", "ok",
                        "tmpfiles.d rule for FIFO present ✓"))


def check_sys_sudoers(rep: Report, fix: bool) -> None:
    if not SUDOERS.exists():
        rep.add(CheckResult("sys.sudoers.exists", "sys", "fail",
                            f"{SUDOERS} missing — bot has no privileges"))
        return
    rc, out, err = _run(["visudo", "-c", "-f", str(SUDOERS)])
    if rc != 0:
        rep.add(CheckResult("sys.sudoers.syntax", "sys", "fail",
                            "Sudoers file has syntax errors", err or out))
        return
    content = SUDOERS.read_text()
    required = [
        ("wg set/show", "/usr/bin/wg"),
        ("wg-quick up wg0", "/usr/bin/wg-quick up wg0"),
        ("wg-save-restore wrapper", "/usr/local/sbin/wg-save-restore"),
        ("systemctl restart wg-quick", "/bin/systemctl restart wg-quick@wg0"),
        ("journalctl", "/usr/bin/journalctl"),
        ("reboot", "/sbin/reboot"),
    ]
    missing = [name for name, needle in required if needle not in content]
    if missing:
        rep.add(CheckResult("sys.sudoers.completeness", "sys", "warn",
                            f"sudoers missing rules: {', '.join(missing)}",
                            "Some bot commands will fail. Reinstall or restore from v0.2.1."))
        return
    rep.add(CheckResult("sys.sudoers", "sys", "ok",
                        "sudoers present, parses clean, has all expected rules ✓"))


def check_sys_helpers(rep: Report, fix: bool) -> None:
    for path, label in [(SAVE_HELPER, "wg-save-restore"),
                        (RESET_HELPER, "wg-bot-reset-admin")]:
        s = _stat_path(path)
        if s is None:
            rep.add(CheckResult(f"sys.helper.{label}", "sys", "fail",
                                f"{label} missing at {path}"))
            continue
        executable = bool(s["mode"] & 0o111)
        if not executable:
            rep.add(CheckResult(f"sys.helper.{label}", "sys", "warn",
                                f"{label} not executable ({s['mode_str']})"))
            continue
        rep.add(CheckResult(f"sys.helper.{label}", "sys", "ok",
                            f"{label} present and executable ✓"))


def check_sys_systemd_units(rep: Report, fix: bool) -> None:
    for unit in ["wg-admin-bot.service", "wg-quick@wg0.service",
                 "wg-vm-digest.timer", "wg-digest.timer",
                 "wg-bot-disk-check.timer"]:
        rc, out, _ = _run(["systemctl", "is-enabled", unit])
        if rc != 0 and "static" not in out:
            rep.add(CheckResult(f"sys.unit.{unit}", "sys", "warn",
                                f"{unit} is {out or 'not enabled'}"))
        else:
            rep.add(CheckResult(f"sys.unit.{unit}", "sys", "ok",
                                f"{unit}: {out} ✓"))


def check_sys_bot_user(rep: Report, fix: bool) -> None:
    try:
        p = pwd.getpwnam("wgbot")
        rep.add(CheckResult("sys.user.wgbot", "sys", "ok",
